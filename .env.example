# Bybit API credentials (LIVE account)
BYBIT_API_KEY=your_live_api_key_here
BYBIT_API_SECRET=your_live_api_secret_here

# Set BOTH to false for LIVE trading
BYBIT_TESTNET=false
BYBIT_DEMO=false

# false = place real orders; true = simulate only (no orders placed)
DRY_RUN=false

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Logging level: DEBUG, INFO, WARNING
LOG_LEVEL=INFO
